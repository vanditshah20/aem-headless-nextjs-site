# AEM base URL (used when AEM_GRAPHQL_ENDPOINT is not set)
AEM_BASE_URL=

# AEM credentials (used when AEM_AUTH_HEADER is not set)
# Format: username:password
AEM_CREDENTIALS=

# AEM GraphQL endpoint URL
# If set, this overrides AEM_BASE_URL + /content/cq:graphql/global/endpoint.json
AEM_GRAPHQL_ENDPOINT=

# Authorization header value (e.g. "Bearer <token>" or "Basic <base64>")
AEM_AUTH_HEADER=

# Example:
# AEM_BASE_URL=https://author.example.com
# AEM_CREDENTIALS=admin:admin
# AEM_GRAPHQL_ENDPOINT=https://author.example.com/content/cq:graphql/global/endpoint.json
# AEM_AUTH_HEADER=Bearer your-token-here
